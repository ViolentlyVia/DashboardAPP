@page "/assets"
@{
  Layout = null;
}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Assets Management</title>
    <link rel="stylesheet" href="/css/assets.css" />
  </head>
  <body>
    <button id="dark-toggle" class="dark-toggle" aria-label="Toggle dark mode">☾</button>
    <div class="container">
      <div class="header-row">
        <h1>Assets Management</h1>
        <a id="back-link" href="/" class="back-button">← Back</a>
      </div>
      <table id="assets-table">
        <thead>
          <tr>
            <th>Friendly Name</th>
            <th>Hostname</th>
            <th>IP Address</th>
            <th>RDP Link</th>
            <th>Uptime</th>
            <th>Last Seen</th>
            <th>CPU %</th>
            <th>Memory %</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="assets-tbody">
          <tr><td colspan="9" class="empty-message">Loading assets...</td></tr>
        </tbody>
      </table>

      <div id="edit-modal" class="modal">
        <div class="modal-content">
          <h2>Edit Asset</h2>
          <div class="form-group">
            <label for="edit-friendly-name">Friendly Name:</label>
            <input type="text" id="edit-friendly-name" placeholder="Enter friendly name (optional)">
          </div>
          <div class="form-group">
            <label for="edit-ip">IP Address:</label>
            <input type="text" id="edit-ip" placeholder="Enter IP address">
          </div>
          <div class="form-group">
            <label for="edit-rdp-url">RDP Launch URL (Guacamole):</label>
            <input type="text" id="edit-rdp-url" placeholder="https://guac.example/#/client/... (optional)">
          </div>
          <div class="modal-buttons">
            <button class="cancel-button" onclick="closeEditModal()">Cancel</button>
            <button class="save-button" onclick="saveAsset()">Save</button>
          </div>
        </div>
      </div>
    </div>
    <script src="/js/assets-page.js?v=1"></script>
  </body>
</html>
