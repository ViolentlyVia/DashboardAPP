@page
@model ManageModel
@{
    ViewData["Title"] = "Management — PulsePoint";
}

<div class="page-header">
  <div>
    <h1 class="page-title">Management</h1>
    <p class="page-sub">Services and asset configuration</p>
  </div>
  <a href="/managelogout" class="btn btn-ghost">Sign Out</a>
</div>

<div class="manage-layout">

  <!-- ── Services ─────────────────────────────────────── -->
  <section class="manage-section">
    <div class="section-header">
      <span class="section-title">Monitored Services</span>
      <span class="badge-count" id="svc-count">—</span>
    </div>

    <div class="table-card" id="svc-table-wrap">
      <table class="asset-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Address / URL</th>
            <th class="col-actions">Remove</th>
          </tr>
        </thead>
        <tbody id="svc-body">
          <tr><td colspan="3" class="loading-cell">Loading…</td></tr>
        </tbody>
      </table>
    </div>

    <div class="add-card">
      <h3 class="add-title">Add service</h3>
      <div class="add-row">
        <input type="text" id="new-svc-name" placeholder="Name (e.g. Nginx)" />
        <input type="text" id="new-svc-addr" placeholder="Address (e.g. 192.168.1.5:80 or http://…)" />
        <button class="btn btn-primary" onclick="addService()">Add</button>
      </div>
      <p class="add-hint">IP:port or full URL — http:// is prepended automatically if omitted.</p>
    </div>
  </section>

  <!-- ── Assets ───────────────────────────────────────── -->
  <section class="manage-section">
    <div class="section-header">
      <span class="section-title">Asset Names</span>
    </div>

    <div class="table-card">
      <table class="asset-table">
        <thead>
          <tr>
            <th>Hostname</th>
            <th>Friendly Name</th>
            <th class="col-actions">Save</th>
          </tr>
        </thead>
        <tbody id="asset-body">
          <tr><td colspan="3" class="loading-cell">Loading…</td></tr>
        </tbody>
      </table>
    </div>
  </section>


  <!-- ── Unraid ─────────────────────────────────────────── -->
  <section class="manage-section">
    <div class="section-header">
      <span class="section-title">Unraid Integration</span>
      <span class="badge-cred" id="unraid-status">—</span>
    </div>
    <div class="cred-form">
      <div class="cred-row">
        <label>Host / IP</label>
        <input type="text" id="unraid-host" placeholder="192.168.1.10" />
      </div>
      <div class="cred-row">
        <label>API Key</label>
        <input type="text" id="unraid-apikey" placeholder="Unraid Connect API key" />
      </div>
      <div class="cred-row">
        <label>API Key ID <span class="cred-optional">(optional)</span></label>
        <input type="text" id="unraid-apikeyid" placeholder="Key ID if required by your Unraid version" />
      </div>
      <div class="cred-row">
        <label>Bearer Token <span class="cred-optional">(optional)</span></label>
        <input type="text" id="unraid-bearer" placeholder="Leave blank if not required" />
      </div>
      <div class="cred-actions">
        <button class="btn btn-primary" onclick="saveUnraid()">Save</button>
        <span class="save-msg" id="unraid-saved"></span>
      </div>
    </div>
  </section>

  <!-- ── Omada ──────────────────────────────────────────── -->
  <section class="manage-section">
    <div class="section-header">
      <span class="section-title">Omada Integration</span>
      <span class="badge-cred" id="omada-status">—</span>
    </div>
    <div class="cred-form">
      <div class="cred-row">
        <label>Controller URL</label>
        <input type="text" id="omada-url" placeholder="https://192.168.1.10:8043" />
      </div>
      <div class="cred-row">
        <label>Omada Controller ID</label>
        <input type="text" id="omada-cid" placeholder="Omada controller ID (omadacId)" />
      </div>
      <div class="cred-row">
        <label>Client ID</label>
        <input type="text" id="omada-clientid" placeholder="OAuth client ID" />
      </div>
      <div class="cred-row">
        <label>Client Secret</label>
        <input type="password" id="omada-secret" placeholder="Leave blank to keep current" />
      </div>
      <div class="cred-row">
        <label>Preferred Site ID <span class="cred-optional">(optional)</span></label>
        <input type="text" id="omada-siteid" placeholder="Auto-selects first site if blank" />
      </div>
      <div class="cred-actions">
        <button class="btn btn-primary" onclick="saveOmada()">Save</button>
        <span class="save-msg" id="omada-saved"></span>
      </div>
    </div>
  </section>

  <!-- ── iDRAC ──────────────────────────────────────────── -->
  <section class="manage-section">
    <div class="section-header">
      <span class="section-title">iDRAC 8 Integration</span>
      <span class="badge-cred" id="idrac-status">—</span>
    </div>
    <div class="cred-form">
      <div class="cred-row">
        <label>Host / IP</label>
        <input type="text" id="idrac-host" placeholder="192.168.1.20" />
      </div>
      <div class="cred-row">
        <label>Username</label>
        <input type="text" id="idrac-user" placeholder="root" />
      </div>
      <div class="cred-row">
        <label>Password</label>
        <input type="password" id="idrac-pass" placeholder="Leave blank to keep current" />
      </div>
      <div class="cred-actions">
        <button class="btn btn-primary" onclick="saveIdrac()">Save</button>
        <span class="save-msg" id="idrac-saved"></span>
      </div>
    </div>
  </section>

</div>

@section Scripts {
<script>
const BASE = '';

// ── Services ──────────────────────────────────────────────
async function loadServices() {
  const r = await fetch(`${BASE}/api/manage/services`);
  if (r.status === 401) { location.href = '/managelogin'; return; }
  const svcs = await r.json();
  document.getElementById('svc-count').textContent = svcs.length;
  document.getElementById('svc-body').innerHTML = svcs.length
    ? svcs.map(s => `
        <tr>
          <td>${esc(s.name)}</td>
          <td class="mono">${esc(s.url)}</td>
          <td class="actions-cell">
            <button class="btn-icon danger" onclick="delService(${s.id})">✕</button>
          </td>
        </tr>`).join('')
    : '<tr><td colspan="3" class="empty-state">No services yet. Add one below.</td></tr>';
}

async function addService() {
  const name = document.getElementById('new-svc-name').value.trim();
  const addr = document.getElementById('new-svc-addr').value.trim();
  if (!name || !addr) { alert('Both name and address are required.'); return; }

  const r = await fetch(`${BASE}/api/manage/services`, {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ name, address: addr })
  });
  if (r.status === 401) { location.href = '/managelogin'; return; }

  document.getElementById('new-svc-name').value = '';
  document.getElementById('new-svc-addr').value = '';
  loadServices();
}

async function delService(id) {
  if (!confirm('Remove this service?')) return;
  await fetch(`${BASE}/api/manage/services/${id}`, { method: 'DELETE' });
  loadServices();
}

// ── Assets ────────────────────────────────────────────────
async function loadAssets() {
  const r = await fetch(`${BASE}/api/manage/assets`);
  if (r.status === 401) { location.href = '/managelogin'; return; }
  const hosts = await r.json();
  document.getElementById('asset-body').innerHTML = hosts.length
    ? hosts.map(h => `
        <tr>
          <td class="mono">${esc(h.hostname)}</td>
          <td>
            <input type="text" class="inline-input" id="fn-${esc(h.hostname)}"
              value="${esc(h.friendlyName || '')}" placeholder="(none)" />
          </td>
          <td class="actions-cell">
            <button class="btn-icon" onclick="saveName('${esc(h.hostname)}')">✓</button>
          </td>
        </tr>`).join('')
    : '<tr><td colspan="3" class="empty-state">No assets found.</td></tr>';
}

async function saveName(hostname) {
  const name = document.getElementById('fn-' + hostname).value.trim();
  const r = await fetch(`${BASE}/api/manage/assets/${encodeURIComponent(hostname)}/name`, {
    method: 'PUT',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ name })
  });
  if (r.status === 401) { location.href = '/managelogin'; return; }
  if (r.ok) flashSaved(hostname);
}

function flashSaved(hostname) {
  const btn = document.querySelector(`[onclick="saveName('${hostname}')"]`);
  if (!btn) return;
  btn.textContent = '✓ Saved';
  btn.style.color = 'var(--ok)';
  setTimeout(() => { btn.textContent = '✓'; btn.style.color = ''; }, 1500);
}

function esc(s) {
  return String(s ?? '').replace(/[&<>"']/g, c =>
    ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// Allow Enter key in the add row
document.addEventListener('keydown', e => {
  if (e.key === 'Enter' &&
      (e.target.id === 'new-svc-name' || e.target.id === 'new-svc-addr'))
    addService();
});

// ── Integration credentials ───────────────────────────────────
async function loadIntegrations() {
  const r = await fetch(`${BASE}/api/manage/integrations`);
  if (r.status === 401) { location.href = '/managelogin'; return; }
  const d = await r.json();

  // Omada
  const omadaR = await fetch(`${BASE}/api/manage/integrations/omada`);
  if (omadaR.ok) {
    const o = await omadaR.json();
    document.getElementById('omada-url').value    = o.baseUrl      || '';
    document.getElementById('omada-cid').value    = o.omadacId     || '';
    document.getElementById('omada-clientid').value = o.clientId   || '';
    document.getElementById('omada-siteid').value = o.preferSiteId || '';
    document.getElementById('omada-status').textContent =
      o.baseUrl ? (o.hasSecret ? '✓ Configured' : '⚠ No secret') : 'Not set';
    document.getElementById('omada-status').style.color =
      o.baseUrl && o.hasSecret ? 'var(--ok)' : 'var(--dim)';
  }

  document.getElementById('unraid-host').value     = d.unraid?.host        || '';
  document.getElementById('unraid-apikey').value   = d.unraid?.apiKey      || '';
  document.getElementById('unraid-apikeyid').value = d.unraid?.apiKeyId    || '';
  document.getElementById('unraid-bearer').value   = d.unraid?.bearerToken || '';
  document.getElementById('unraid-status').textContent =
    d.unraid?.host ? '✓ Configured' : 'Not set';
  document.getElementById('unraid-status').style.color =
    d.unraid?.host ? 'var(--ok)' : 'var(--dim)';

  document.getElementById('idrac-host').value = d.idrac?.host     || '';
  document.getElementById('idrac-user').value = d.idrac?.username || '';
  // password intentionally not loaded back
  document.getElementById('idrac-status').textContent =
    d.idrac?.host ? (d.idrac.hasPassword ? '✓ Configured' : '⚠ No password') : 'Not set';
  document.getElementById('idrac-status').style.color =
    d.idrac?.host && d.idrac?.hasPassword ? 'var(--ok)' : 'var(--dim)';
}

async function saveUnraid() {
  const payload = {
    host:        document.getElementById('unraid-host').value.trim(),
    apiKey:      document.getElementById('unraid-apikey').value.trim(),
    apiKeyId:    document.getElementById('unraid-apikeyid').value.trim(),
    bearerToken: document.getElementById('unraid-bearer').value.trim()
  };
  if (!payload.host || !payload.apiKey) { alert('Host and API Key are required.'); return; }
  const r = await fetch(`${BASE}/api/manage/integrations/unraid`, {
    method: 'PUT',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify(payload)
  });
  if (r.status === 401) { location.href = '/managelogin'; return; }
  flashMsg('unraid-saved', r.ok ? '✓ Saved' : '✕ Error');
  if (r.ok) loadIntegrations();
}

async function saveIdrac() {
  const payload = {
    host:     document.getElementById('idrac-host').value.trim(),
    username: document.getElementById('idrac-user').value.trim(),
    password: document.getElementById('idrac-pass').value
  };
  if (!payload.host || !payload.username) { alert('Host and Username are required.'); return; }
  const r = await fetch(`${BASE}/api/manage/integrations/idrac`, {
    method: 'PUT',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify(payload)
  });
  if (r.status === 401) { location.href = '/managelogin'; return; }
  flashMsg('idrac-saved', r.ok ? '✓ Saved' : '✕ Error');
  if (r.ok) {
    document.getElementById('idrac-pass').value = '';
    loadIntegrations();
  }
}

function flashMsg(id, msg) {
  const el = document.getElementById(id);
  el.textContent = msg;
  el.style.color = msg.startsWith('✓') ? 'var(--ok)' : 'var(--crit)';
  setTimeout(() => { el.textContent = ''; }, 2500);
}

async function saveOmada() {
  const payload = {
    baseUrl:      document.getElementById('omada-url').value.trim(),
    omadacId:     document.getElementById('omada-cid').value.trim(),
    clientId:     document.getElementById('omada-clientid').value.trim(),
    clientSecret: document.getElementById('omada-secret').value,
    preferSiteId: document.getElementById('omada-siteid').value.trim()
  };
  if (!payload.baseUrl || !payload.omadacId || !payload.clientId) {
    alert('Controller URL, Controller ID, and Client ID are required.');
    return;
  }
  const r = await fetch(`${BASE}/api/manage/integrations/omada`, {
    method: 'PUT',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify(payload)
  });
  if (r.status === 401) { location.href = '/managelogin'; return; }
  flashMsg('omada-saved', r.ok ? '✓ Saved' : '✕ Error');
  if (r.ok) {
    document.getElementById('omada-secret').value = '';
    loadIntegrations();
  }
}

loadServices();
loadAssets();
loadIntegrations();
</script>
}
