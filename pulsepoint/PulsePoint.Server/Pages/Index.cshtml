@page
@model IndexModel
@inject AppState State
@{
    ViewData["Title"] = "Dashboard — PulsePoint";
    var _ap = State.GetAppearance();
    var _hm = _ap.HiddenMetricsSet;
}

<div class="page-header">
  <div>
    <h1 class="page-title">Dashboard</h1>
    <p class="page-sub" id="last-updated">Loading…</p>
  </div>
  <div class="header-stats" id="header-stats"></div>
</div>

<div class="dashboard-layout @(_ap.HideServicesWidget ? "no-sidebar" : "")">
  <section class="hosts-section">
    <div class="section-header">
      <span class="section-title">Endpoints</span>
      <span class="badge-count" id="host-count">—</span>
    </div>
    <div class="host-grid" id="host-grid">
      <div class="skeleton-grid">
        @for (int i = 0; i < 6; i++)
        {
          <div class="host-card skeleton"></div>
        }
      </div>
    </div>
  </section>

  @if (!_ap.HideServicesWidget)
  {
  <aside class="sidebar">
    <div class="sidebar-block">
      <div class="section-header">
        <span class="section-title">Services</span>
        <span class="badge-count" id="svc-count">—</span>
      </div>
      <div id="services-list" class="services-list"></div>
    </div>
  </aside>
  }
</div>

@section Scripts {
<script>
const KEY = '@Model.Key';
const BASE = '';
const REFRESH_MS = @(_ap.RefreshInterval * 1000);
const ONLINE_SEC = @_ap.OnlineThreshold;
const HIDDEN_METRICS = new Set([@Html.Raw(string.Join(",", _ap.HiddenMetricsSet.Select(m => $"'{m}'")))]);

async function load() {
  try {
    const r = await fetch(`${BASE}/api/summary?key=${KEY}`);
    if (!r.ok) { showError(r.status); return; }
    const d = await r.json();
    renderHosts(d.hosts);
    renderServices(d.services);
    document.getElementById('last-updated').textContent =
      'Updated ' + new Date().toLocaleTimeString();
  } catch(e) {
    document.getElementById('last-updated').textContent = 'Connection error';
  }
}

function renderHosts(data) {
  const now = Math.floor(Date.now() / 1000);
  const online = data.list.filter(h => now - h.lastSeen < ONLINE_SEC);
  const offline = data.list.filter(h => now - h.lastSeen >= ONLINE_SEC);

  document.getElementById('header-stats').innerHTML = `
    <div class="stat-pill online"><span class="pulse-dot"></span>${online.length} Online</div>
    <div class="stat-pill offline">${offline.length} Offline</div>
  `;
  document.getElementById('host-count').textContent = data.total;

  const sorted = [...online, ...offline];
  document.getElementById('host-grid').innerHTML = sorted.length
    ? sorted.map(h => hostCard(h, now)).join('')
    : '<p class="empty-state">No endpoints reporting yet.</p>';
}

function hostCard(h, now) {
  const isOnline = now - h.lastSeen < ONLINE_SEC;
  const name = h.friendlyName || h.hostname;
  const uptime = formatUptime(h.uptime);
  const ping = h.ping != null ? `${Math.round(h.ping)}ms` : '—';
  const cpu = h.cpu != null ? h.cpu.toFixed(1) : '0.0';
  const mem = h.memory != null ? h.memory.toFixed(1) : '0.0';
  const disk = h.disk != null ? h.disk.toFixed(1) : null;
  const lastSeen = formatAge(now - h.lastSeen);

  const rdpBtn = h.rdpUrl
    ? `<a href="${h.rdpUrl}" class="rdp-btn" title="Open RDP">⇥ RDP</a>` : '';

  return `
  <div class="host-card ${isOnline ? 'online' : 'offline'}">
    <div class="host-card-header">
      <div class="host-indicator ${isOnline ? 'online' : 'offline'}"></div>
      <div class="host-name-block">
        <span class="host-name">${escHtml(name)}</span>
        ${name !== h.hostname ? `<span class="host-sub">${escHtml(h.hostname)}</span>` : ''}
      </div>
      ${rdpBtn}
    </div>
    <div class="host-ip">${escHtml(h.ip)}</div>
    <div class="host-metrics">
      ${!HIDDEN_METRICS.has('cpu') ? `
      <div class="metric">
        <span class="metric-label">CPU</span>
        <span class="metric-val ${metricClass(parseFloat(cpu))}">${cpu}%</span>
        <div class="metric-bar"><div class="metric-fill ${metricClass(parseFloat(cpu))}" style="width:${cpu}%"></div></div>
      </div>` : ''}
      ${!HIDDEN_METRICS.has('memory') ? `
      <div class="metric">
        <span class="metric-label">RAM</span>
        <span class="metric-val ${metricClass(parseFloat(mem))}">${mem}%</span>
        <div class="metric-bar"><div class="metric-fill ${metricClass(parseFloat(mem))}" style="width:${mem}%"></div></div>
      </div>` : ''}
      ${disk != null && !HIDDEN_METRICS.has('disk') ? `
      <div class="metric">
        <span class="metric-label">Disk</span>
        <span class="metric-val ${metricClass(parseFloat(disk))}">${disk}%</span>
        <div class="metric-bar"><div class="metric-fill ${metricClass(parseFloat(disk))}" style="width:${disk}%"></div></div>
      </div>` : ''}
    </div>
    <div class="host-footer">
      ${!HIDDEN_METRICS.has('ping')   ? `<span title="Ping">${isOnline ? '◈ ' + ping : '✕ Offline'}</span>` : (!isOnline ? '<span>✕ Offline</span>' : '')}
      ${!HIDDEN_METRICS.has('uptime') ? `<span title="Uptime">${isOnline ? '↑ ' + uptime : 'Last: ' + lastSeen}</span>` : ''}
    </div>
  </div>`;
}

function renderServices(data) {
  document.getElementById('svc-count').textContent = data.total;
  document.getElementById('services-list').innerHTML = data.total === 0
    ? '<p class="empty-state">No services configured.</p>'
    : data.list.map(s => `
      <div class="service-row">
        <span class="svc-dot ${s.online ? 'online' : 'offline'}"></span>
        <span class="svc-name">${escHtml(s.name)}</span>
        <span class="svc-meta">${s.online ? (s.responseMs ? Math.round(s.responseMs)+'ms' : 'OK') : 'Down'}</span>
      </div>`).join('');
}

function metricClass(v) {
  if (v >= 90) return 'crit';
  if (v >= 70) return 'warn';
  return 'ok';
}

function formatUptime(s) {
  if (!s) return '—';
  const d = Math.floor(s / 86400), h = Math.floor((s % 86400) / 3600), m = Math.floor((s % 3600) / 60);
  if (d > 0) return `${d}d ${h}h`;
  if (h > 0) return `${h}h ${m}m`;
  return `${m}m`;
}

function formatAge(s) {
  if (s < 60) return 'just now';
  if (s < 3600) return Math.floor(s/60) + 'm ago';
  if (s < 86400) return Math.floor(s/3600) + 'h ago';
  return Math.floor(s/86400) + 'd ago';
}

function escHtml(s) {
  return String(s).replace(/[&<>"']/g, c =>
    ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

load();
setInterval(load, REFRESH_MS);
</script>
}
