<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@(ViewData["Title"] ?? "PulsePoint")</title>
  <link rel="stylesheet" href="/css/pulse.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%237c3aed'/><polyline points='4,16 10,16 13,8 16,24 19,12 22,16 28,16' fill='none' stroke='white' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'/></svg>" />
</head>
<body>
@{
    var apiKey      = ViewData["ApiKey"] as string ?? "";
    var kq          = string.IsNullOrEmpty(apiKey) ? "" : $"?key={apiKey}";
    var curPage     = ViewData["Page"] as string ?? "";
    var urlDash     = "/" + kq;
    var urlAssets   = "/assets" + kq;
    var urlServices = "/services" + kq;
}
  <div id="app">
    <nav class="nav">
      <a href="@urlDash" class="nav-brand">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3,12 7.5,12 10,5 12,19 14.5,9 17,12 21,12"/>
        </svg>
        PulsePoint
      </a>
      <div class="nav-links">
        <a href="@urlDash"     class="@(curPage == "dashboard" ? "active" : "")">Dashboard</a>
        <a href="@urlAssets"   class="@(curPage == "assets"    ? "active" : "")">Assets</a>
        <a href="@urlServices" class="@(curPage == "services"  ? "active" : "")">Services</a>
      </div>
      <span class="nav-clock" id="clock"></span>
      <a href="/manage" class="nav-manage @(curPage == "manage" ? "active" : "")">⚙ Manage</a>
    </nav>
    <main class="main">
      @RenderBody()
    </main>
  </div>
  <script src="/js/pulse.js"></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
